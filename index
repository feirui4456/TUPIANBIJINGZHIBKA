<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>飛書指標卡展示與配置面板</title>
    <style>
        /* ==========================================
           1. 基礎環境設定
           ========================================== */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        body {
            background-color: #f0f2f5; /* 飛書標準背景灰 */
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            position: relative;
        }

        /* ==========================================
           2. 側邊自動隱藏設置面板 (Hover 小條觸發)
           ========================================== */
        .setting-sidebar-container {
            position: fixed;
            right: 0;
            top: 50%;
            transform: translate(100%, -50%); /* 預設完全隱藏在螢幕右側外 */
            display: flex;
            align-items: center;
            z-index: 1000;
            transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        /* 觸發小條 */
        .setting-trigger-bar {
            width: 28px;
            height: 90px;
            background-color: #3370ff; /* 飛書品牌藍 */
            color: #ffffff;
            font-size: 14px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 8px 0 0 8px;
            cursor: pointer;
            box-shadow: -3px 0 10px rgba(31, 35, 41, 0.12);
            transform: translateX(-100%); /* 讓小條突出來貼在螢幕邊緣 */
            writing-mode: vertical-lr; /* 文字直排 */
            letter-spacing: 2px;
            user-select: none;
        }

        /* 設置面板本體 */
        .setting-panel {
            width: 300px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-left: 1px solid rgba(31, 35, 41, 0.15);
            box-shadow: -4px 0 24px rgba(31, 35, 41, 0.1);
            padding: 24px;
            height: 400px;
            border-radius: 12px 0 0 12px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* 🔥 核心互動：滑鼠觸及小條或面板時，整體滑出 */
        .setting-sidebar-container:hover {
            transform: translate(0, -50%);
        }

        /* 設置項表單樣式 */
        .panel-title {
            font-size: 16px;
            font-weight: 600;
            color: #1f2329;
            margin-bottom: 8px;
            border-bottom: 1px solid rgba(31, 35, 41, 0.08);
            padding-bottom: 8px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group label {
            font-size: 12px;
            color: #646a73;
            font-weight: 500;
        }

        .form-group input, .form-group select {
            padding: 8px 12px;
            border: 1px solid rgba(31, 35, 41, 0.15);
            border-radius: 6px;
            font-size: 14px;
            color: #1f2329;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group input:focus, .form-group select:focus {
            border-color: #3370ff;
        }

        /* ==========================================
           3. 飛書風格指標卡組件
           ========================================== */
        .fs-metric-card {
            position: relative;
            width: 340px;
            height: 310px;
            border-radius: 16px;
            /* 背景圖與顏色會透過 JS 讀取設定動態改變 */
            background-image: url('https://images.unsplash.com/photo-1524661135-423995f22d0b?auto=format&fit=crop&w=400&q=80');
            background-size: cover;
            background-position: center;
            box-shadow: 0 8px 24px rgba(31, 35, 41, 0.08);
            border: 1px solid rgba(31, 35, 41, 0.06);
            padding: 12px;
            transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease;
            cursor: pointer;
        }

        /* 內層磨砂玻璃 */
        .fs-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            border-radius: 12px;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.75) 0%, rgba(255, 255, 255, 0.92) 100%);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: background 0.3s ease;
        }

        .fs-metric-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(31, 35, 41, 0.16);
        }

        .fs-metric-card:hover .fs-card-inner {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.65) 0%, rgba(255, 255, 255, 0.85) 100%);
        }

        /* 指標卡內部排版 */
        .fs-header { display: flex; justify-content: space-between; align-items: center; }
        .fs-title { font-size: 22px; font-weight: 600; color: #1f2329; }
        .fs-icon { width: 26px; height: 26px; color: #1f2329; }
        
        .fs-body { margin-top: 12px; }
        .fs-label { font-size: 13px; color: #8f959e; margin-bottom: 4px; }
        .fs-value-wrapper { display: flex; align-items: baseline; }
        .fs-value { font-size: 42px; font-weight: 700; color: #1f2329; letter-spacing: -1px; }
        .fs-unit { font-size: 16px; color: #1f2329; margin-left: 6px; font-weight: 500; }

        .fs-footer { display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto; }
        .fs-sub-block { display: flex; flex-direction: column; gap: 4px; }
        .fs-sub-title { font-size: 13px; color: #8f959e; }
        .fs-sub-content { font-size: 16px; font-weight: 500; color: #1f2329; }
        
        /* 趨勢特化樣式，預設紅色 */
        .fs-trend-value { color: #f54a45; transition: color 0.2s; }
    </style>
</head>
<body>

    <div class="fs-metric-card" id="metricCard">
        <div class="fs-card-inner">
            <div class="fs-header">
                <span class="fs-title" id="cardTitle">Q季度營收目標</span>
                <svg class="fs-icon" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M11 2v10h10A10 10 0 0 0 11 2zm2 12.38v6.15A8 8 0 0 0 19.62 14H13zm-4-.38A8 8 0 0 0 3 6.38v11.24A8 8 0 0 0 9 14z"/>
                </svg>
            </div>
            
            <div class="fs-body">
                <div class="fs-label">Icon</div>
                <div class="fs-value-wrapper">
                    <span class="fs-value" id="cardValue">1,425.8</span>
                    <span class="fs-unit" id="cardUnit">萬元</span>
                </div>
            </div>

            <div class="fs-footer">
                <div class="fs-sub-block">
                    <span class="fs-sub-title">Trend</span>
                    <span class="fs-sub-content fs-trend-value" id="cardTrend">▲ 12.4%</span>
                </div>
                <div class="fs-sub-block" style="text-align: right;">
                    <span class="fs-sub-title">Period</span>
                    <span class="fs-sub-content" id="cardPeriod">相較上季</span>
                </div>
            </div>
        </div>
    </div>

    <div class="setting-sidebar-container">
        <div class="setting-trigger-bar">⚙️ 配置面板</div>
        
        <div class="setting-panel">
            <div class="panel-title">指標卡實時配置</div>
            
            <div class="form-group">
                <label for="inputBg">背景圖片網址 (URL)</label>
                <input type="text" id="inputBg" value="https://images.unsplash.com/photo-1524661135-423995f22d0b?auto=format&fit=crop&w=400&q=80">
            </div>

            <div class="form-group">
                <label for="inputTitle">指標名稱 (Title)</label>
                <input type="text" id="inputTitle" value="Q季度營收目標">
            </div>

            <div class="form-group">
                <label for="inputValue">核心數值 (Value)</label>
                <input type="text" id="inputValue" value="1,425.8">
            </div>

            <div class="form-group">
                <label for="inputUnit">單位 (Unit)</label>
                <input type="text" id="inputUnit" value="萬元">
            </div>

            <div class="form-group">
                <label for="inputTrend">趨勢標籤 (Trend)</label>
                <input type="text" id="inputTrend" value="▲ 12.4%">
            </div>

            <div class="form-group">
                <label for="selectColor">趨勢顏色主題</label>
                <select id="selectColor">
                    <option value="#f54a45">飛書紅 (看跌/警示)</option>
                    <option value="#34a853">通用綠 (看漲/良率)</option>
                </select>
            </div>
        </div>
    </div>

    <script>
        // 綁定所有輸入項與對應的卡片 DOM 節點
        const inputBg = document.getElementById('inputBg');
        const inputTitle = document.getElementById('inputTitle');
        const inputValue = document.getElementById('inputValue');
        const inputUnit = document.getElementById('inputUnit');
        const inputTrend = document.getElementById('inputTrend');
        const selectColor = document.getElementById('selectColor');

        const metricCard = document.getElementById('metricCard');
        const cardTitle = document.getElementById('cardTitle');
        const cardValue = document.getElementById('cardValue');
        const cardUnit = document.getElementById('cardUnit');
        const cardTrend = document.getElementById('cardTrend');

        // 即時監聽函數：當輸入框內容改變，卡片立即更新
        inputBg.addEventListener('input', (e) => {
            metricCard.style.backgroundImage = `url('${e.target.value}')`;
        });

        inputTitle.addEventListener('input', (e) => {
            cardTitle.textContent = e.target.value;
        });

        inputValue.addEventListener('input', (e) => {
            cardValue.textContent = e.target.value;
        });

        inputUnit.addEventListener('input', (e) => {
            cardUnit.textContent = e.target.value;
        });

        inputTrend.addEventListener('input', (e) => {
            cardTrend.textContent = e.target.value;
        });

        selectColor.addEventListener('change', (e) => {
            cardTrend.style.color = e.target.value;
        });
    </script>
</body>
</html>
